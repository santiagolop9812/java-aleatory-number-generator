import java.util.Random;

/**
 * RandomNumberGenerator
 * 
 * This class provides a method to generate pseudo-random numbers
 * within a specified range.
 * 
 * Author: Santiago Fuentes Lopez
 */

public class RandomNumberGenerator {

    /**
     * Generates a random integer between min and max.
     * 
     * @param min the minimum value
     * @param max the maximum value
     * @return random integer between min and max
     */
    public static int generateRandomNumber(int min, int max) {

        Random random = new Random();

        int randomNumber = random.nextInt((max - min) + 1) + min;

        return randomNumber;
    }

    /**
     * Main method to demonstrate how the method works.
     */
    public static void main(String[] args) {

        System.out.println("Generating 10 random numbers between 1 and 100:");

        for (int i = 0; i < 10; i++) {

            int number = generateRandomNumber(1, 100);

            System.out.println("Random number: " + number);
        }
    }
}
